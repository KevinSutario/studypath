# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/learnlens
# Supabase/Neon:  copy the connection string from your dashboard
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/learnlens"

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters, ideally 64+
# Generate a strong secret with:  openssl rand -base64 64
JWT_SECRET="replace_this_with_at_least_64_random_characters_do_not_use_this_value"

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Used for on-demand question generation and learning-style explanation
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL — no trailing slash
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "production" on your hosting platform
NODE_ENV="development"
